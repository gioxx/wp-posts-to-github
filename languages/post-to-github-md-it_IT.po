msgstr "%d post esportati con successo."

#: includes/functions.php:80
#, php-format
msgid "%d failed:"
msgstr "%d falliti:"

#: includes/functions.php:88
msgid "Testing…"
msgstr "Verifica in corso…"

#: includes/GithubClient.php:54
msgid "Invalid GitHub token."
msgstr "Token GitHub non valido."

#: includes/GithubClient.php:58
msgid "Repository not found or not accessible with this token."
msgstr "Repository non trovato o non accessibile con questo token."

#: includes/GithubClient.php:63 includes/GithubClient.php:82
#, php-format
msgid "GitHub API error, HTTP %d."
msgstr "Errore delle API GitHub, HTTP %d."

#: includes/GithubClient.php:78
#, php-format
msgid "Branch \"%s\" not found in repository."
msgstr "Il branch \"%s\" non è stato trovato nel repository."

#: includes/GithubClient.php:85
msgid "Connection successful: repository and branch are reachable."
msgstr "Connessione riuscita: repository e branch sono raggiungibili."

#: includes/GithubClient.php:122
msgid ""
"(the file may have been modified directly on GitHub: check the repository "
"contents before re-exporting)"
msgstr ""
"(il file potrebbe essere stato modificato direttamente su GitHub: verifica "
"il contenuto del repository prima di ri-esportare)"

#: includes/Metabox.php:11 includes/Metabox.php:31
msgid "Export to GitHub"
msgstr "Esporta su GitHub"

#: includes/Metabox.php:42
#, php-format
msgid "Exported on %s"
msgstr "Esportato il %s"

#: includes/Metabox.php:44
msgid "Modified since last export"
msgstr "Modificato dopo l'ultima esportazione"

#: includes/Metabox.php:46
msgid "Never exported"
msgstr "Mai esportato"

#: includes/Settings.php:64 includes/Settings.php:65 includes/Settings.php:86
msgid "Post to GitHub MD"
msgstr "Post to GitHub MD"

#: includes/Settings.php:91
msgid "GitHub Personal Access Token"
msgstr "Token di accesso personale GitHub"

#: includes/Settings.php:98
#, php-format
msgid ""
"A fine-grained or classic token with %s access to the target repository. "
"Generate one at %s."
msgstr ""
"Un token fine-grained o classico con accesso %s al repository di "
"destinazione. Generane uno su %s."

#: includes/Settings.php:107
msgid "Repository"
msgstr "Repository"

#: includes/Settings.php:111
msgid ""
"Enter either \"owner/repo\" or the full GitHub URL (e.g. https://github.com/"
"owner/repo)."
msgstr ""
"Inserisci \"owner/repo\" oppure l'URL completo di GitHub (es. https://"
"github.com/owner/repo)."

#: includes/Settings.php:116
msgid "Branch"
msgstr "Branch"

#: includes/Settings.php:120
msgid "The branch posts will be committed to (e.g. main)."
msgstr "Il branch su cui verranno pubblicati i post (es. main)."

#: includes/Settings.php:125
msgid "Base folder"
msgstr "Cartella base"

#: includes/Settings.php:129
msgid "Repository folder posts are exported into (e.g. posts)."
msgstr "Cartella del repository in cui vengono esportati i post (es. posts)."

#: includes/Settings.php:139
msgid "Test connection"
msgstr "Verifica connessione"

#: includes/Settings.php:164
msgid ""
"Enter both a token and a valid repository before testing the connection."
msgstr ""
"Inserisci sia un token che un repository valido prima di verificare la "
"connessione."
