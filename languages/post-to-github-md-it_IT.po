msgid "Insufficient permissions."
msgstr "Permessi insufficienti."

#: includes/BulkPage.php:78 includes/Metabox.php:73
msgid "Configure the PAT and repository in the plugin settings first."
msgstr "Configura prima PAT e repository nelle impostazioni del plugin."

#: includes/functions.php:40
msgid "Post not found."
msgstr "Post non trovato."

#: includes/functions.php:44
msgid "Only published posts can be exported."
msgstr "Solo i post pubblicati possono essere esportati."

#: includes/functions.php:68
msgid "Network error during export."
msgstr "Errore di rete durante l'esportazione."

#: includes/functions.php:76 includes/functions.php:89
msgid "Network error."
msgstr "Errore di rete."

#: includes/functions.php:78
